    class Program
    {
        static void Main(string[] args)
        {

            int a, b, soma;
            
            Console.Write("Digite o 1º valor a ser somado: ");
            a = int.Parse(Console.ReadLine());
            Console.Write("Digite o 2º valor a ser somado: ");
            b = int.Parse(Console.ReadLine());
            Console.Clear();

            soma = (a + b);
            Console.WriteLine("O resultado é: {0} ", soma);
            
            Console.ReadKey();

        }
    }
